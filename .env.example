# Copy to .env (or set via `fly secrets set ...`) for production.
# Backend reads these via DENTAL_ prefix (pydantic-settings).

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
DENTAL_JWT_SECRET=

# Mark as production so the app refuses to boot with the dev secret.
DENTAL_ENVIRONMENT=production

# Override if FE/BE are cross-origin (e.g. Cloudflare Pages + Fly.io backend).
# JSON array of origins, e.g. ["https://dental.example.com"]
DENTAL_CORS_ORIGINS=[]

# Anthropic Claude API — drives /api/ai/chat (clinical AI dock + patient mobile).
# Get a key at https://console.anthropic.com/settings/keys (recommend setting a
# monthly spend limit at the same console). When unset, /api/ai/chat returns a
# stubbed fallback so the UI still works in dev.
DENTAL_ANTHROPIC_API_KEY=
DENTAL_ANTHROPIC_MODEL=claude-sonnet-4-6
DENTAL_ANTHROPIC_MAX_TOKENS=1024
